# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# In EasyPanel: use the internal service name as HOST
DATABASE_URL=postgresql://jengibre_user:YOUR_DB_PASSWORD@postgres:5432/jengibre_db

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_minimum_32_chars
JWT_EXPIRES_IN=24h

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Your public frontend domain (no trailing slash)
FRONTEND_URL=https://jengibre.tudominio.com
